# Dependencies — installed fresh via npm ci in Docker
node_modules/

# Credentials — injected via Cloud Run env vars at runtime
google-credentials.json
google-token.json
.env
.env.example

# Dev/test files — not needed in the Docker image
tests/
vitest.config.js

# Per-run diagnostic artifacts — contain personal calendar data, never ship them
runs/

# Separate web frontend — not part of the job image
web/

# Docs and local files — not needed in the image
*.log
*.md
.git/
.gitignore
.gcloudignore
implementation_plan.md
